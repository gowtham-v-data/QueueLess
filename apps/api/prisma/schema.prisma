generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  STAFF
  ORG_ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DELETED
}

enum OrganizationStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum CounterStatus {
  AVAILABLE
  BUSY
  PAUSED
  OFFLINE
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum QueueStatus {
  WAITING
  CALLED
  SKIPPED
  COMPLETED
  CANCELLED
  PAUSED
}

enum QueuePriority {
  EMERGENCY
  VIP
  SENIOR_CITIZEN
  NORMAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
  BROWSER
}

enum NotificationStatus {
  UNREAD
  READ
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

model User {
  id                         String                @id @default(cuid())
  firstName                  String
  lastName                   String
  email                      String                @unique
  phone                      String?               @unique
  passwordHash               String
  avatarUrl                  String?
  role                       UserRole              @default(CUSTOMER)
  status                     UserStatus            @default(ACTIVE)
  isEmailVerified            Boolean               @default(false)
  emailVerificationToken     String?               @unique
  emailVerificationExpiresAt DateTime?
  passwordResetToken         String?               @unique
  passwordResetExpiresAt     DateTime?
  lastLoginAt                DateTime?
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  memberships                OrganizationMembership[]
  ownedOrganizations         Organization[]        @relation("OrganizationOwner")
  createdBranches             Branch[]              @relation("BranchCreator")
  createdServices             Service[]             @relation("ServiceCreator")
  assignedCounters           Counter[]              @relation("CounterStaff")
  customerQueues             Queue[]                @relation("QueueCustomer")
  createdNotifications        Notification[]        @relation("NotificationCreator")
  queueEvents                 QueueEvent[]
  notifications              Notification[]
  feedbackEntries             Feedback[]            @relation("FeedbackCustomer")
  generatedReports            Report[]
  refreshTokens              RefreshToken[]
  auditLogs                   AuditLog[]            @relation("AuditActor")
}

model Organization {
  id                String                    @id @default(cuid())
  name              String
  slug              String                    @unique
  tagline           String?
  logoUrl           String?
  primaryColor      String?
  status            OrganizationStatus        @default(PENDING)
  ownerId           String?
  settings          Json?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  owner             User?                     @relation("OrganizationOwner", fields: [ownerId], references: [id])
  memberships       OrganizationMembership[]
  branches          Branch[]
  services          Service[]
  counters          Counter[]
  queues            Queue[]
  notifications     Notification[]
  feedbackEntries   Feedback[]
  subscriptions     Subscription[]
  reports           Report[]
  auditLogs         AuditLog[]
}

model OrganizationMembership {
  id              String             @id @default(cuid())
  userId          String
  organizationId  String
  role            UserRole
  title           String?
  status          MembershipStatus   @default(ACTIVE)
  isPrimary       Boolean            @default(false)
  joinedAt        DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, role])
  @@index([organizationId, role])
}

model Branch {
  id              String         @id @default(cuid())
  organizationId  String
  name            String
  slug            String
  address         String
  city            String
  state           String?
  country         String
  postalCode      String?
  phone           String?
  email           String?
  latitude        Decimal?       @db.Decimal(10, 8)
  longitude       Decimal?       @db.Decimal(11, 8)
  workingHours    Json?
  holidays        Json?
  qrCodeUrl       String?
  status          BranchStatus   @default(ACTIVE)
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy       User?          @relation("BranchCreator", fields: [createdById], references: [id], onDelete: SetNull)
  services        Service[]
  counters        Counter[]
  queues          Queue[]
  feedbackEntries Feedback[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
}

model Service {
  id                    String         @id @default(cuid())
  organizationId        String
  branchId              String?
  name                  String
  description           String?
  tokenPrefix           String
  currentSequence       Int            @default(0)
  averageDurationMins   Int            @default(10)
  isPriorityEnabled     Boolean        @default(true)
  queueLimit            Int?
  status                ServiceStatus  @default(ACTIVE)
  createdById           String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch                Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBy             User?          @relation("ServiceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  counters              Counter[]
  queues                Queue[]
  feedbackEntries       Feedback[]

  @@unique([organizationId, branchId, name])
  @@index([organizationId, branchId, status])
}

model Counter {
  id              String        @id @default(cuid())
  organizationId  String
  branchId        String
  serviceId       String?
  assignedStaffId String?
  name            String
  code            String
  status          CounterStatus @default(AVAILABLE)
  currentQueueId  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  service         Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  assignedStaff   User?         @relation("CounterStaff", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  currentQueue    Queue?        @relation("CurrentCounterQueue", fields: [currentQueueId], references: [id], onDelete: SetNull)
  queues          Queue[]

  @@unique([organizationId, branchId, code])
  @@unique([currentQueueId])
  @@index([branchId, status])
}

model Queue {
  id                   String          @id @default(cuid())
  organizationId       String
  branchId             String
  serviceId            String
  customerId           String
  counterId            String?
  tokenCode            String
  tokenNumber          Int
  priority             QueuePriority   @default(NORMAL)
  status               QueueStatus     @default(WAITING)
  positionSnapshot     Int?
  estimatedWaitMins    Int?
  source               String          @default("web")
  notes                String?
  calledAt             DateTime?
  completedAt          DateTime?
  skippedAt            DateTime?
  cancelledAt          DateTime?
  pausedAt             DateTime?
  resumedAt            DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  organization         Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch               Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  service              Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  customer             User            @relation("QueueCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  counter              Counter?        @relation(fields: [counterId], references: [id], onDelete: SetNull)
  currentCounter       Counter?        @relation("CurrentCounterQueue")
  events               QueueEvent[]
  notifications        Notification[]
  feedback             Feedback?

  @@unique([organizationId, tokenCode])
  @@index([branchId, serviceId, status, priority])
  @@index([customerId, status])
}

model QueueEvent {
  id            String      @id @default(cuid())
  queueId       String
  type          String
  payload       Json?
  createdById   String?
  createdAt     DateTime    @default(now())

  queue         Queue       @relation(fields: [queueId], references: [id], onDelete: Cascade)
  createdBy     User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([queueId, type])
}

model RefreshToken {
  id            String   @id @default(cuid())
  userId        String
  tokenHash     String   @unique
  deviceInfo    String?
  ipAddress     String?
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Notification {
  id              String              @id @default(cuid())
  organizationId  String?
  userId          String
  queueId         String?
  title           String
  body            String
  channel         NotificationChannel  @default(IN_APP)
  status          NotificationStatus   @default(UNREAD)
  metadata        Json?
  readAt          DateTime?
  createdById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  organization    Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  queue           Queue?              @relation(fields: [queueId], references: [id], onDelete: SetNull)
  createdBy       User?               @relation("NotificationCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId, status])
}

model Feedback {
  id              String     @id @default(cuid())
  customerId      String
  organizationId  String
  branchId        String?
  serviceId       String?
  queueId         String?    @unique
  rating          Int
  comment         String?
  status          String     @default("VISIBLE")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  customer        User       @relation("FeedbackCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  service         Service?   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  queue           Queue?     @relation(fields: [queueId], references: [id], onDelete: SetNull)

  @@index([organizationId, rating])
}

model Subscription {
  id              String             @id @default(cuid())
  organizationId  String
  planName        String
  status          SubscriptionStatus @default(TRIAL)
  billingCycle    String             @default("monthly")
  seats           Int                @default(1)
  startsAt        DateTime           @default(now())
  endsAt          DateTime?
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

model Report {
  id              String      @id @default(cuid())
  organizationId  String
  generatedById   String?
  type            String
  format          String
  fileUrl         String
  fileName        String
  filters         Json?
  generatedAt     DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generatedBy     User?        @relation(fields: [generatedById], references: [id], onDelete: SetNull)

  @@index([organizationId, type])
}

model AuditLog {
  id              String    @id @default(cuid())
  actorId         String?
  organizationId  String?
  action          String
  entityType      String
  entityId        String?
  metadata        Json?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())

  actor           User?      @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId, action])
}
